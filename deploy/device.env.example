# /etc/kallon/device.env  (mode 0640 root:RUNTIME_USER)
#
# Single per-device configuration file consumed by the Kallon installer
# (scripts/install/*), the watchdog, the WireGuard provisioner, and the
# enrollment client. Copy to /etc/kallon/device.env and fill in the values.
#
# Canonical install procedure — see docs/identity-and-secrets.md §3.2
# Copy device.env + alert.key to /tmp/ on the Jetson first (§3.2 A), then:
#
#   RUNTIME_USER="${SUDO_USER:-$(logname 2>/dev/null || id -un)}"
#   sudo install -d -m 0750 -o root -g "$RUNTIME_USER" /etc/kallon
#   sudo install -m 0640 -o root -g "$RUNTIME_USER" /tmp/device.env /etc/kallon/device.env
#   sudo sed -i 's/\r$//' /etc/kallon/device.env
#   sudo install -m 0640 -o root -g "$RUNTIME_USER" /tmp/alert.key /etc/kallon/alert.key
#   sudo sed -i 's/\r$//' /etc/kallon/alert.key
#   sudoedit /etc/kallon/device.env
#
# NEVER commit a real device.env. This .example file is the only version in git.

# ─────────────────────────────────────────────────────────────────────────────
# Host  (set this — makes the golden image fully device-agnostic)
# ─────────────────────────────────────────────────────────────────────────────
RUNTIME_USER=your-jetson-login     # Linux user that runs Kallon systemd services
                                   # e.g. sentinel, ubuntu, khalifa — whatever
                                   # account was created when the OS was set up.

# ─────────────────────────────────────────────────────────────────────────────
# Identity  (formats are locked — see docs/identity-and-secrets.md)
# ─────────────────────────────────────────────────────────────────────────────
DEVICE_ID=kln_acme_000042          # kln_<customer-slug>_<6-digit serial>
CUSTOMER_ID=cust_acme              # cust_<slug>
CLAIM_CODE=clm_REPLACE_ME          # clm_<base64url 16 bytes>, printed on the QR label

# ─────────────────────────────────────────────────────────────────────────────
# WAN policy  (Wi-Fi primary, LTE fallback — see roadmap §7)
# ─────────────────────────────────────────────────────────────────────────────
WAN_MODE=wifi                      # wifi | lte  (which iface is the *intended* primary)
WAN_IFACE=wlP1p1s0                 # primary WAN: internet, SSH, WireGuard, enrollment
WAN_FALLBACK_IFACE=usb0            # LTE modem; demoted to a higher route metric (blank to disable)
WAN_METRIC=100                     # route metric for WAN_IFACE (lower = preferred)
WAN_FALLBACK_METRIC=700            # route metric for WAN_FALLBACK_IFACE (higher = fallback)

# ─────────────────────────────────────────────────────────────────────────────
# Camera segment  (single Ethernet port = camera VLAN only, NEVER a default route)
# ─────────────────────────────────────────────────────────────────────────────
CAMERA_IFACE=enP8p1s0              # Orin Nano onboard NIC
CAMERA_SUBNET=192.168.10.0/24
CAMERA_JETSON_IP=192.168.10.2/24   # Jetson address on the camera segment
CAMERA_IPS=192.168.10.108,192.168.10.109   # comma-separated, one /32 per camera
CAMERA_RTSP_USER=admin
CAMERA_PASSWORD=REPLACE_ME         # camera ONVIF/RTSP password (kept in this file only)
# Quoted: bash `source` treats bare & as background. subtype=0 main, 1 sub.
# Hub remuxes whatever camN publishes — use subtype=1 for stable buyer HLS.
CAMERA_RTSP_PATH='/cam/realmonitor?channel=1&subtype=1'
CAMERA_ONVIF_PORT=80               # ONVIF HTTP port for PTZ (try 8899 if 80 is closed); shared by all cameras

# ─────────────────────────────────────────────────────────────────────────────
# WireGuard  (rendered by kallon-wg-provision.sh; keys never live here)
# ─────────────────────────────────────────────────────────────────────────────
WG_IFACE=wg0
WG_PRIVATE_KEY_PATH=/etc/wireguard/jetson.private   # mode 600, generated on-device
VPN_IP=10.50.0.2/32                # /32 allocated by the registry at enrollment
GATEWAY_ENDPOINT=203.0.113.42:51820
GATEWAY_PUBLIC_KEY=REPLACE_ME
VPN_SUBNET=10.50.0.0/24            # AllowedIPs scope (NOT 0.0.0.0/0)

# ─────────────────────────────────────────────────────────────────────────────
# Enrollment  (first-boot auto-enroll against the Terra control plane)
# ─────────────────────────────────────────────────────────────────────────────
ENROLLMENT_URL=https://enroll.terra.example/v1
ENROLLMENT_TOKEN=enr_REPLACE_ME    # enr_<base64url 32 bytes>, one-time use, baked at factory

# ─────────────────────────────────────────────────────────────────────────────
# Alerts  (kallon-watchdog → hub alert listener over wg0)
# ─────────────────────────────────────────────────────────────────────────────
ALERT_WEBHOOK_URL=http://10.50.0.1:8080/alerts
ALERT_KEY_PATH=/etc/kallon/alert.key                # 32-byte HMAC key, mode 0640, on tower + hub

# Comma-separated; defaults to the local mediamtx paths rendered from CAMERA_IPS.
RTSP_URLS=rtsp://127.0.0.1:8554/cam1,rtsp://127.0.0.1:8554/cam2

# Watchdog tuning (defaults shown).
POLL_INTERVAL_SEC=10
TEMP_TRIGGER_C=80
TEMP_CLEAR_C=75
DEDUP_WINDOW_SEC=60

# Hardware wiring (Jetson Orin Nano J12, BOARD numbering).
MPU_I2C_BUS=7
MPU_I2C_ADDR=0x68
GPIO_REED_PIN=31
GPIO_LDR_PIN=33
MPU_ACCEL_THRESHOLD_MG=150

# Optional subsystems — flip to 1 once hardware is installed.
ENABLE_NVME=1                      # set 1 whenever an NVMe SSD is present (SMART health alerts)
NVME_DEVICE=/dev/nvme0
ENABLE_POWER_ADC=0

# ─────────────────────────────────────────────────────────────────────────────
# Local recording  (edge NVR — continuous, rolling retention)
# ─────────────────────────────────────────────────────────────────────────────
# mediamtx always writes to RECORD_PATH. When an NVMe SSD is present and
# writable, kallon-ensure-recordings-mount (boot + module 50) mounts it there:
#   - prefer partition LABEL=kallon-rec
#   - else reclaim any non-root NVMe data partition (even if GNOME mounted it
#     under /media/…)
#   - if the OS image itself boots from NVMe and there is no separate data
#     volume, RECORD_PATH on root is already SSD — no extra mount needed
# Never relies on /media/... paths in mediamtx.yml.
#
# Maps to mediamtx path settings (see scripts/install/50-mediamtx.sh):
#   RECORD_MEDIAMTX_SEGMENT_FILE_DURATION → recordSegmentDuration (each .mp4 file on disk)
#   RECORD_MEDIAMTX_DELETE_AFTER          → recordDeleteAfter (rolling retention)
# recordPartDuration (internal 1s flush) is fixed in the installer — not configurable.
RECORD_ENABLE=0
RECORD_PATH=/var/kallon/recordings
RECORD_MEDIAMTX_DELETE_AFTER=168h             # mediamtx safety net (7d) — uploader deletes sooner after S3 verify
RECORD_MEDIAMTX_SEGMENT_FILE_DURATION=15m       # each segment file on disk (15 minutes)

# ─────────────────────────────────────────────────────────────────────────────
# Cloud upload  (Backblaze B2 S3-compatible — upload-before-delete)
# ─────────────────────────────────────────────────────────────────────────────
# Tower writes 15m fmp4 segments locally, uploads to the shared B2 bucket under:
#   s3://$S3_BUCKET/$DEVICE_ID/camN/<filename>.mp4
# (optional S3_PREFIX prepended). Platform presigns playback; tower key is write-only.
# NEVER commit real keys — apply on-device via sudoedit /etc/kallon/device.env
RECORD_UPLOAD_ENABLE=0
S3_BUCKET=sentinel-recordings
S3_REGION=us-east-005
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_PREFIX=
AWS_ACCESS_KEY_ID=REPLACE_ME_B2_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_ME_B2_APPLICATION_KEY
# Platform base URL for POST /v1/recordings/ingest (defaults from ENROLLMENT_URL host).
# RECORD_UPLOAD_PLATFORM_URL=https://kallon-sentry-production.up.railway.app
# Shared ingest token — set same value as KALLON_RECORDING_INGEST_TOKEN on Platform.
# RECORD_UPLOAD_INGEST_TOKEN=REPLACE_ME
RECORD_UPLOAD_POLL_SEC=60
RECORD_UPLOAD_STABLE_SEC=120
RECORD_UPLOAD_CONCURRENCY=2
RECORD_LOCAL_DELETE_AFTER_UPLOAD=1
RECORD_LOCAL_GRACE_MIN=15

# ─────────────────────────────────────────────────────────────────────────────
# Tower lab dashboard  (optional — in-house bench tower with local monitor only)
# ─────────────────────────────────────────────────────────────────────────────
# Installed by scripts/install/85-tower-dashboard.sh when set to 1.
# Loopback-only services; fleet towers leave this at 0 (default).
ENABLE_TOWER_DASHBOARD=0
TOWER_DASHBOARD_PORT=8766         # gateway SPA + API (127.0.0.1 only)
TOWER_STATUS_API_PORT=8770        # watchdog GET /status (127.0.0.1 only)
TOWER_DASHBOARD_KIOSK=1           # 1 = Chromium kiosk autostart on desktop login
# ALERT_WEBHOOK_URL_LOCAL=http://127.0.0.1:8080/alerts  # optional override; auto-set when dashboard enabled
