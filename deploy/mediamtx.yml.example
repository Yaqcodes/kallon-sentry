# /etc/mediamtx.yml — RTSP rebroadcast on the Jetson.
#
# The installer (scripts/install/50-mediamtx.sh) renders the real config from
# device.env. This hand-edit example shows the minimal RTSP-only structure.
#
# Replace placeholders before using manually:
#   CAM_PASSWORD    — from CAMERA_PASSWORD in device.env
#   CAMERA_IP       — one entry per camera from CAMERA_IPS in device.env
#
# Restrict file mode to 0640 root:RUNTIME_USER so the password is not
# world-readable:  sudo chmod 0640 /etc/mediamtx.yml
rtspAddress: :8554
protocols: [tcp]
# Optional loopback-only servers for the on-Jetson tower lab dashboard:
# api: yes
# apiAddress: 127.0.0.1:9997
# hls: yes
# hlsAddress: 127.0.0.1:8888
# hlsVariant: lowLatency
# rtmp: no
# webrtc: no
paths:
  cam1:
    source: "rtsp://admin:CAM_PASSWORD@CAMERA_IP:554/cam/realmonitor?channel=1&subtype=0"
    sourceOnDemand: yes
    rtspTransport: tcp
