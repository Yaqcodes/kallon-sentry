# /etc/mediamtx.yml — Phase 3 RTSP rebroadcast on the Jetson.
#
# `subtype=1` is the secondary stream (lower bitrate, easier on uplink); use
# `subtype=0` for the main stream when bandwidth allows. Replace `CAM_PASSWORD`
# with the camera's ONVIF/RTSP password and (preferably) restrict file mode to
# 0640 root:khalifa so the password is not world-readable.
#
# NOTE: the installer (scripts/install/50-mediamtx.sh) renders the real config
# and additionally enables the Control API (127.0.0.1:9997) and HLS
# (127.0.0.1:8888) on loopback for the optional on-Jetson tower lab dashboard,
# and disables RTMP/WebRTC. This hand-edit example keeps just the RTSP essentials.
rtspAddress: :8554
protocols: [tcp]
# Optional loopback-only servers for the on-Jetson tower lab dashboard:
# api: yes
# apiAddress: 127.0.0.1:9997
# hls: yes
# hlsAddress: 127.0.0.1:8888
# hlsVariant: fmp4
# rtmp: no
# webrtc: no
paths:
  cam1:
    source: rtsp://admin:CAM_PASSWORD@192.168.1.108:554/cam/realmonitor?channel=1&subtype=1
    sourceOnDemand: yes
    rtspTransport: tcp
