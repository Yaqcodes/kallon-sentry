# Railway environment for Kallon enrollment + Platform API
# Copy into Railway → Variables (or use `railway variables set`).
#
# Postgres: attach Railway Postgres plugin — it provides DATABASE_URL automatically.
# Prefer the *private* DATABASE_URL when available (same project network).

# ── Required ─────────────────────────────────────────────────────────────────
KALLON_REGISTRY=postgres
# DATABASE_URL=               # set by Railway Postgres plugin
KALLON_PEER_BACKEND=subprocess
KALLON_PROXY_VIA_HUB=1
KALLON_HUB_PROXY_TOKEN=       # MUST match hub /etc/kallon/hub-proxy.env HUB_PROXY_TOKEN
KALLON_PLATFORM_API_KEY=      # dashboard / SDK X-Kallon-Api-Key

# Ops SSH key for peer-add (pick ONE). Prefer base64 — safer in env UIs.
#   powershell: [Convert]::ToBase64String([IO.File]::ReadAllBytes('C:\kallon\secrets\terra-hub-ops.pem'))
KALLON_OPS_SSH_IDENTITY_B64=
# Or paste the full PEM (including BEGIN/END lines) as a multiline variable:
# KALLON_OPS_SSH_IDENTITY=

# ── CORS (Vercel dashboard) ──────────────────────────────────────────────────
# Comma-separated origins, no trailing slash.
KALLON_CORS_ORIGINS=https://sentinel-dashboard.vercel.app,http://localhost:5173

# ── Optional / defaults ──────────────────────────────────────────────────────
KALLON_HUB_PROXY_PORT=8767
KALLON_HUB_HLS_PORT=8768
KALLON_PROXY_CONNECT_TIMEOUT=5
KALLON_LIVE_READ_TIMEOUT=60
# ENROLLMENT_HMAC_KEY=        # optional tower body HMAC
# KALLON_ALERT_INGEST_TOKEN=  # optional alert ingest gate
# KALLON_INIT_SCHEMA=1        # only if you skip releaseCommand; leave unset normally

# Railway sets PORT automatically — do not hardcode 8000 in the service settings.
